# === Копируем в .env на сервере, заполняем реальными значениями ===

# --- Домен ---
# Фронтенд (Timeweb apps) и API-поддомен на Yandex Cloud VM (93.77.178.53)
SITE_URL=https://faktura-wood.com
API_EXTERNAL_URL=https://api.faktura-wood.com
SUPABASE_PUBLIC_URL=https://api.faktura-wood.com
ADDITIONAL_REDIRECT_URLS=https://faktura-wood.com,https://www.faktura-wood.com

# --- Postgres ---
POSTGRES_PASSWORD=CHANGE_ME_openssl_rand_hex_32
POSTGRES_DB=postgres
POSTGRES_HOST=db
POSTGRES_PORT=5432

# --- JWT ---
# openssl rand -hex 32
JWT_SECRET=CHANGE_ME_openssl_rand_hex_32
JWT_EXPIRY=3600

# ANON_KEY и SERVICE_ROLE_KEY генерируются из JWT_SECRET по инструкции:
# https://supabase.com/docs/guides/self-hosting/docker#generate-api-keys
ANON_KEY=eyJ...
SERVICE_ROLE_KEY=eyJ...

# --- Studio (админка supabase) ---
DASHBOARD_USERNAME=admin
DASHBOARD_PASSWORD=CHANGE_ME

# --- Auth (GoTrue) ---
DISABLE_SIGNUP=false
ENABLE_EMAIL_SIGNUP=true
ENABLE_EMAIL_AUTOCONFIRM=false
ENABLE_ANONYMOUS_USERS=false
# ADDITIONAL_REDIRECT_URLS уже задан выше

# SMTP — Timeweb Mail для домена (ящик no-reply@faktura-wood.com)
SMTP_ADMIN_EMAIL=no-reply@faktura-wood.com
SMTP_HOST=smtp.timeweb.ru
SMTP_PORT=465
SMTP_USER=no-reply@faktura-wood.com
SMTP_PASS=CHANGE_ME
SMTP_SENDER_NAME=FAKTURA

# --- Прикладные секреты (переносим 1-в-1 из Lovable Cloud) ---
ADMIN_PASSWORD=CHANGE_ME
TINKOFF_TERMINAL_KEY=
TINKOFF_PASSWORD=
YANDEX_DELIVERY_TOKEN=
PEK_API_LOGIN=
PEK_API_KEY=
CDEK_ACCOUNT=
CDEK_SECURE_PASSWORD=

# --- Storage backend ---
# Файлы лежат на диске VM в /var/lib/faktura/storage (SSD 100 GB)
STORAGE_BACKEND=file
FILE_STORAGE_BACKEND_PATH=/var/lib/faktura/storage

# --- Бэкапы ---
# backup.sh складывает дампы Postgres в /var/backups/faktura (ротация 14 дней)
BACKUP_DIR=/var/backups/faktura
BACKUP_RETENTION_DAYS=14
