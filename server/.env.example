# === Копируем в .env на сервере, заполняем реальными значениями ===

# --- Домен ---
SITE_URL=https://faktura.ru
API_EXTERNAL_URL=https://api.faktura.ru
SUPABASE_PUBLIC_URL=https://api.faktura.ru

# --- Postgres ---
POSTGRES_PASSWORD=CHANGE_ME_openssl_rand_hex_32
POSTGRES_DB=postgres
POSTGRES_HOST=db
POSTGRES_PORT=5432

# --- JWT ---
# openssl rand -hex 32
JWT_SECRET=CHANGE_ME_openssl_rand_hex_32
JWT_EXPIRY=3600

# ANON_KEY и SERVICE_ROLE_KEY генерируются из JWT_SECRET по инструкции:
# https://supabase.com/docs/guides/self-hosting/docker#generate-api-keys
ANON_KEY=eyJ...
SERVICE_ROLE_KEY=eyJ...

# --- Studio (админка supabase) ---
DASHBOARD_USERNAME=admin
DASHBOARD_PASSWORD=CHANGE_ME

# --- Auth (GoTrue) ---
DISABLE_SIGNUP=false
ENABLE_EMAIL_SIGNUP=true
ENABLE_EMAIL_AUTOCONFIRM=false
ENABLE_ANONYMOUS_USERS=false
ADDITIONAL_REDIRECT_URLS=https://faktura.ru

# SMTP для писем подтверждения (например, Yandex Mail для домена)
SMTP_ADMIN_EMAIL=no-reply@faktura.ru
SMTP_HOST=smtp.yandex.ru
SMTP_PORT=465
SMTP_USER=no-reply@faktura.ru
SMTP_PASS=CHANGE_ME
SMTP_SENDER_NAME=FAKTURA

# --- Прикладные секреты (переносим 1-в-1 из Lovable Cloud) ---
ADMIN_PASSWORD=CHANGE_ME
TINKOFF_TERMINAL_KEY=
TINKOFF_PASSWORD=
YANDEX_DELIVERY_TOKEN=
PEK_API_LOGIN=
PEK_API_KEY=
CDEK_ACCOUNT=
CDEK_SECURE_PASSWORD=

# --- Storage backend ---
# file  — файлы на диске VM (/var/lib/faktura/storage)
# s3    — Yandex Object Storage (рекомендуется)
STORAGE_BACKEND=s3
GLOBAL_S3_BUCKET=faktura-storage
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=ru-central1
STORAGE_S3_ENDPOINT=https://storage.yandexcloud.net
STORAGE_S3_FORCE_PATH_STYLE=true

# --- Бэкапы (backup.sh → Yandex Object Storage) ---
S3_BACKUP_BUCKET=faktura-backups
S3_BACKUP_ENDPOINT=https://storage.yandexcloud.net
